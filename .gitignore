# Credentials & secrets
.credentials.json
mcp-needs-auth-cache.json
secrets/

# Discord (contains personal channel IDs and bot tokens)
channels/

# Session & runtime state
projects/
debug/
logs/
transcripts/
sessions/
shell-snapshots/
tasks/
todos/
plans/
telemetry/
statsig/
usage-data/
file-history/
history.jsonl
paste-cache/
session-env/

# Cache
stats-cache.json
*-cache.json
cache/

# Backups & snapshots
backups/
*.backup-*
*.backup

# Plugins (auto-generated by Claude Code on install, contains machine-specific paths)
plugins/

# Chrome extension binary
chrome/

# Agents (managed by plugins, reinstalled automatically)
agents/

# Hooks runtime artifacts
hooks/*.log
hooks/__pycache__/

# Root-level runtime logs
*.log

# Python bytecode
__pycache__/
*.pyc

# External plugin-managed skills (symlinks to ~/.agents/)
skills/gws-*
skills/persona-*
skills/recipe-*
skills/vercel-react-best-practices

# OS files
.DS_Store
