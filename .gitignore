**/*.pyc

# OS files
.DS_Store
commands.bak-*/

# Auto-generated update timestamp
.last-cleanup
.last-update-result.json

# Machine/account-managed state (Claude Code internal, not user config)
policy-limits.json

# Backup files
*.bak-*
